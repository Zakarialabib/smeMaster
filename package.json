{
  "name": "smemaster",
  "version": "1.0.0",
  "private": true,
  "license": "Apache-2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0",
    "lint:ci": "eslint \"src/**/*.{ts,tsx}\" --max-warnings=0 && prettier --check \"src/**/*.{ts,tsx}\"",
    "format": "prettier --write \"src/**/*.{ts,tsx,css,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build",
    "translate:sync": "node scripts/sync-translations.js",
    "translate:clean": "node scripts/clean-unused-translations.js",
    "check:event-contract": "node scripts/check-event-contract.mjs",
    "android": "cargo tauri android dev",
    "android:build": "cargo tauri android build",
    "android:build:aab": "cargo tauri android build --aab",
    "android:build:apk": "cargo tauri android build --apk",
    "android:init": "cargo tauri android init",
    "generate-icons": "tauri icon src-tauri/icons/icon.png",
    "windows:build": "cargo tauri build --target x86_64-pc-windows-msvc",
    "windows:portable": "cargo tauri build --bundles nsis --target x86_64-pc-windows-msvc",
    "prepare": "husky"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx}": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "src/**/*.{css,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.74.0",
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@tanstack/react-query": "^5.100.10",
    "@tanstack/react-router": "^1.159.5",
    "@tanstack/react-virtual": "^3.13.24",
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-biometric": "^2.3.2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-deep-link": "^2.4.9",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-fs": "^2.5.1",
    "@tauri-apps/plugin-global-shortcut": "^2.3.2",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-store": "^2.4.2",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@tauri-apps/plugin-window-state": "^2.4.1",
    "@tiptap/extension-color": "^3.19.0",
    "@tiptap/extension-highlight": "^3.19.0",
    "@tiptap/extension-image": "^3.19.0",
    "@tiptap/extension-link": "^3.19.0",
    "@tiptap/extension-mention": "^3.23.4",
    "@tiptap/extension-placeholder": "^3.19.0",
    "@tiptap/extension-table": "^3.23.2",
    "@tiptap/extension-table-cell": "^3.23.2",
    "@tiptap/extension-table-header": "^3.23.2",
    "@tiptap/extension-table-row": "^3.23.2",
    "@tiptap/extension-text-align": "^3.19.0",
    "@tiptap/extension-text-style": "^3.19.0",
    "@tiptap/extension-underline": "^3.19.0",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/react": "^3.19.0",
    "@tiptap/starter-kit": "^3.19.0",
    "@tiptap/suggestion": "^3.23.4",
    "@types/d3-force": "^3.0.10",
    "@xyflow/react": "^12.11.1",
    "d3-force": "^3.0.0",
    "date-fns": "^4.4.0",
    "dompurify": "^3.4.0",
    "i18next": "^26.1.0",
    "lucide-react": "^0.563.0",
    "openai": "^6.38.0",
    "papaparse": "^5.5.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.7",
    "react-intersection-observer": "^10.0.3",
    "react-transition-group": "^4.4.5",
    "recharts": "^2.15.4",
    "tailwindcss-animate": "^1.0.1",
    "tsdav": "^2.1.8",
    "uuid": "^14.0.0",
    "zustand": "^5.0.11"
  },
  "overrides": {
    "react-is": "19.2.4"
  },
  "optionalDependencies": {
    "@rollup/rollup-win32-x64-msvc": "^4.60.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/cli": "^2.11.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/dompurify": "^3.0.5",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.13",
    "@types/react-dom": "^19.2.3",
    "@types/react-transition-group": "^4.4.12",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/parser": "^8.59.3",
    "@vitejs/plugin-react": "^5.1.3",
    "eslint": "^9.39.0",
    "eslint-plugin-import": "^2.31.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.3",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.0.18"
  }
}
